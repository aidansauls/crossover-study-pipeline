# =============================================================================
# .gitignore -- Crossover Study Analysis Pipeline
# Copyright (c) 2026 Aidan Sauls
# =============================================================================

# ---- Real study data (never commit participant data) ----
study_data/*/
!study_data/README.md

# ---- Generated outputs (reproducible; often large) ----
outputs/

# ---- Sensitive outputs that should never be shared ----
**/InternalUse/

# ---- R session artifacts ----
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ---- OS junk ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Stray log files in root ----
comparison_log*.txt
*.log

# ---- Package cache ----
renv/library/
renv/.cache/

# =============================================================================
# NOTE: example_data/ is intentionally NOT ignored — it ships with the repo
#       so new users can run the pipeline immediately.
# =============================================================================
